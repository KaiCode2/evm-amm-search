# Copy to .env and set one endpoint. HTTPS RPC URLs are converted to WSS for
# the live TUI subscription connection.
WS_RPC_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# E2E_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# Optional HTTP state/cold-start provider pool. When set, pool discovery,
# cold-start, cache reads, and route simulations use load-balanced batched
# HTTP transport with gzip. Keep WS_RPC_URL set for block/log subscriptions.
# AMM_ROUTE_TUI_RPC_URLS=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY,https://mainnet.infura.io/v3/YOUR_KEY
# AMM_ROUTE_TUI_RPC_BATCH_SIZE=150

# Persistent EvmCache is enabled by default. Cache state, registrations, and
# canonical checkpoint are committed as one crash-consistent generation on
# orderly shutdown. Use a separate directory per concurrently running TUI.
AMM_ROUTE_TUI_PERSIST_CACHE=1
AMM_ROUTE_TUI_CACHE_DIR=.cache/amm-route-tui
# Verified checkpoints at most this many blocks behind the current head are
# replayed exactly. Older checkpoints discard persisted EVM state and rebuild
# at the latest block while retaining registration/read-set hints.
# AMM_ROUTE_TUI_MAX_WARM_CATCHUP_BLOCKS=256
# Startup pool coverage defaults to 128. Set 0 to admit every discovered pool
# during startup; focused and deferred discovery can extend the graph later.
# AMM_ROUTE_TUI_MAX_POOLS=128
# AMM_ROUTE_TUI_EXHAUSTIVE_SEARCH=0
# Once focused discovery is idle, backfill the remaining configured-token pairs
# through the runtime's deferred scheduler class.
# AMM_ROUTE_TUI_BACKGROUND_DISCOVERY=1

# Optional token/pool overlay. If unset, the TUI auto-detects
# .amm-route-tui.toml or amm-route-tui.toml in the current directory.
# AMM_ROUTE_TUI_CONFIG=.amm-route-tui.toml
# Optional token-list registry for symbol lookup in the TUI token picker.
# Set to off to disable symbol lookup for tokens not already in the selector list.
# AMM_ROUTE_TUI_TOKEN_REGISTRY_URL=https://tokens.uniswap.org
# AMM_ROUTE_TUI_TOKEN_REGISTRY_TIMEOUT_SECS=5

# USD annotations are fetched from CoinGecko by default.
AMM_ROUTE_TUI_PRICES=1
AMM_ROUTE_TUI_PRICE_SOURCE=coingecko
# CoinGecko Demo/free API key. COINGECKO_API_KEY is also accepted.
# AMM_ROUTE_TUI_COINGECKO_API_KEY=
# Pro/paid API key. Uses https://pro-api.coingecko.com automatically.
# AMM_ROUTE_TUI_COINGECKO_PRO_API_KEY=
# AMM_ROUTE_TUI_PRICE_TIMEOUT_SECS=5
# Leave these unset to use mode-aware defaults:
# - keyless: 10 one-address requests every 60s, spaced 2.1s apart
# - demo/pro key: 60 one-address requests every 60s, spaced 0.5s apart
# AMM_ROUTE_TUI_PRICE_REFRESH_SECS=60
# AMM_ROUTE_TUI_COINGECKO_REQUESTS_PER_REFRESH=
# AMM_ROUTE_TUI_COINGECKO_REQUEST_DELAY_MS=
# Warn when priced output loses at least this many basis points versus priced
# input. The default is 1000 (10%); 0 warns on any estimated value loss.
# AMM_ROUTE_TUI_MAX_VALUE_LOSS_BPS=1000

# Local DemoRouter gas benchmarking against the exact immutable live snapshot.
# AMM_ROUTE_TUI_GAS_ESTIMATES=1

# Optional independent Tenderly replay of the displayed versioned live route.
# The TUI pins the quote block at its end-of-block transaction index, verifies
# its hash before and after the request, prefunds only DemoRouter's input-token
# balance, and checks returned amountOut.
# TENDERLY_API_KEY=
# TENDERLY_ACCOUNT_SLUG=
# TENDERLY_PROJECT_SLUG=
# Transaction sender for the simulation. No token balance or allowance is
# injected for this address; DemoRouter is prefunded directly. If unset, the
# TUI uses 0x...dead.
# AMM_ROUTE_TUI_SIMULATE_FROM=0x1111111111111111111111111111111111111111
# Maximum accepted difference between quoted and Tenderly output. Defaults to
# 1 basis point; use 0 to require an exact raw-unit match.
# AMM_ROUTE_TUI_TENDERLY_OUTPUT_TOLERANCE_BPS=1
